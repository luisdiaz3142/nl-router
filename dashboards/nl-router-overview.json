  "description": "End-to-end view of an nl-router deployment: receiver → router → dispatcher → cleaner, plus module-worker queues and the management API. Variables ($server_id, $datasource) filter to one node / one Prometheus source.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Receiver",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "type": "timeseries",
      "title": "Associations — accept vs reject (rate/s)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 101,
      "targets": [
        {
          "expr": "sum by (result) (rate(nl_receiver_associations_total{server_id=~\"$server_id\"}[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "stat",
      "title": "Active associations",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 102,
      "targets": [
        {
          "expr": "sum(nl_receiver_associations_active{server_id=~\"$server_id\"})",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Workers busy / total",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 103,
      "targets": [
        {
          "expr": "sum(nl_receiver_workers_busy{server_id=~\"$server_id\"})",
          "legendFormat": "busy",
          "refId": "A"
        },
        {
          "expr": "sum(nl_receiver_workers_total{server_id=~\"$server_id\"})",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Landing zone usage",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
