        {
          "expr": "sum(nl_receiver_landing_disk_free_bytes{server_id=~\"$server_id\"})",
          "legendFormat": "free",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
